tel 1.0 https://tel-lang.org/schema/tel-schema

# The TEL schema-for-schemas. Self-describing: parsing this document under the
# schema it defines yields a valid semantic model. The vocabulary is specified
# in §20.5 of the TEL Specification.

name tel-schema

# ---------------------------------------------------------------------------
# Definitions. Each `define` is, in effect, a named Struct: it gives a
# reusable name to a list of members so that recursive schemas may be
# expressed in finite form. A definition has a `name` (inline atom) followed
# directly by its members; no `struct` wrapper is required because the body
# is always a list of Members.
# ---------------------------------------------------------------------------

# The body of a Layer (name, optional definitions, root struct).

record layer-body
  field name identifier
  field define define-body repeatable
  field root struct-body

# The body of a definition (name + members).

record define-body
  field name identifier
  select repeatable
    variant field field-body
    variant select select-body

# The body of a Struct (a list of Members; each Member is field or select).

record struct-body
  select repeatable
    variant field field-body
    variant select select-body

# The body of a Field (keyword first, then optional flags, then type).
# Keyword-first ordering lets a field be declared inline as
# `field some-keyword repeatable` without ambiguity.

record field-body
  field keyword identifier
  field required flag
  field repeatable flag
  select required
    variant struct struct-body
    variant scalar scalar-body
    variant flag flag
    variant type reference-body

# The body of a Select (required, repeatable, list of variants).

record select-body
  field required flag
  field repeatable flag
  field variant variant-body repeatable

# The body of a Variant (keyword + type).

record variant-body
  field keyword identifier
  select required
    variant struct struct-body
    variant scalar scalar-body
    variant flag flag
    variant type reference-body

# The body of a Scalar (validator + optional default).

record scalar-body
  field validator identifier
  field default string

# The body of a Reference (a single name).

record reference-body
  field name identifier

# ---------------------------------------------------------------------------
# The schema document struct. Describes the top-level members of every TEL
# schema document, including this one.
# ---------------------------------------------------------------------------

document
  field name identifier
  field sigil sigil
  field define define-body repeatable
  field document struct-body
  field layer layer-body repeatable
