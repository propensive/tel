        },
        Block {
            comments: [
                Comment {
                    text: "---------------------------------------------------------------------------",
                },
                Comment {
                    text: "Definitions. Each `define` is, in effect, a named Struct: it gives a",
                },
                Comment {
                    text: "reusable name to a list of members so that recursive schemas may be",
                },
                Comment {
                    text: "expressed in finite form. A definition has a `name` (inline atom) followed",
                },
                Comment {
                    text: "directly by its members; no `struct` wrapper is required because the body",
                },
                Comment {
                    text: "is always a list of Members.",
                },
                Comment {
                    text: "---------------------------------------------------------------------------",
                },
            ],
            tabulation: None,
            compounds: [],
            trailing_blank_lines: 1,
